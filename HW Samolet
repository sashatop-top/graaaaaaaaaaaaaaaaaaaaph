    def heuristic(self, frm, to, plane: Plane) -> float:
        edge = Road(frm, to, 0)
        return edge.len() / plane.cruise_speed
    
    def restore_path(self, parent, state, g, fuel_spent_dict):
        path = []
        all_time = g[state]
        all_fuel = fuel_spent_dict[state]
        refuel_count = 0
        
        while state is not None:
            p_info = parent[state]
            if p_info is None:
                path.append((state[0], None, 0, 0, False))
                break
            
            prev_state, road, travel_time, fuel_spent, was_refuel = p_info
            if was_refuel:
                refuel_count += 1
            path.append((state[0], road, travel_time, fuel_spent, was_refuel))
            state = prev_state
        
        path.reverse()
        return path, all_time, all_fuel, refuel_count
    
