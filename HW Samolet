from math import pi, sin, cos, asin, sqrt, atan2

class City:
    def __init__(self, name, lat, lon, has_fuel: bool = True):
        self.name = name
        self.lat = lat
        self.lon = lon
        self.has_fuel = has_fuel
    
    def __repr__(self) -> str:
        return self.name

class Plane:
    def __init__(self, tank_capacity: int = 16000, base_fuel: float = 2.7, cruise_speed: int = 841, empty_mass: int = 30000) -> None:
        self.tank_capacity = tank_capacity
        self.base_fuel = base_fuel
        self.cruise_speed = cruise_speed
        self.empty_mass = empty_mass
    
    def M(self, fuel_current_mass) -> float:
        return self.empty_mass + fuel_current_mass

    def v_mass(self, fuel_current: float):
        return self.cruise_speed * (1 - 0.1 * fuel_current / self.tank_capacity)
    
    def mass_factor(self, fuel_current) -> float:
        return 1 + 0.3 * fuel_current / self.tank_capacity

class Road:
    def __init__(self, city1, city2, wind_direction: float):
        self.city1 = city1
        self.city2 = city2
        self.wind_direction = wind_direction
    
    def __repr__(self):
        return f"{self.city1} - {self.city2}"

    @staticmethod
    def hav(phi: float) -> float:
        return sin(phi / 2) ** 2
    
    @staticmethod
    def rads(deg: float) -> float:
        return deg * pi / 180
    
    def len(self) -> float:
        R = 6371.0
        lat1 = self.city1.lat
        lat2 = self.city2.lat
        lon1 = self.city1.lon
        lon2 = self.city2.lon
        
        dlat = lat2 - lat1
        dlon = lon2 - lon1
        
        lat1_rad = self.rads(lat1)
        lat2_rad = self.rads(lat2)
        dlat_rad = self.rads(dlat)
        dlon_rad = self.rads(dlon)
        
        a = self.hav(dlat_rad) + cos(lat1_rad) * cos(lat2_rad) * self.hav(dlon_rad)
        c = 2 * asin(min(1, sqrt(a)))
        return R * c
    
    def azimut(self) -> float:
        lon1 = self.city1.lon
        lon2 = self.city2.lon
        lat1 = self.city1.lat
        lat2 = self.city2.lat
        
        dlon = lon2 - lon1
        dlon_rad = self.rads(dlon)
        lat1_rad = self.rads(lat1)
        lat2_rad = self.rads(lat2)
        
        y = sin(dlon_rad) * cos(lat2_rad)
        x = cos(lat1_rad) * sin(lat2_rad) - sin(lat1_rad) * cos(lat2_rad) * cos(dlon_rad)
        return atan2(y, x)
    
    def delta_theta(self) -> float:
        az = self.azimut()
        wind_rad = self.rads(self.wind_direction)
        return az - wind_rad
    
    def speed_multiplier(self) -> float:
        return 1 + 0.05 * cos(self.delta_theta())
    
    def v_effective(self, v_mass: float) -> float:
        return self.speed_multiplier() * v_mass
    
    def wind_factor(self) -> float:
        return 1 + 0.2 * (1 - cos(self.delta_theta()))
    
    def fuel_rate(self, plane: Plane, fuel_current: float) -> float:
        return plane.base_fuel * plane.mass_factor(fuel_current) * self.wind_factor()
    
    def fuel(self, plane: Plane, fuel_current: float) -> float:
        return self.fuel_rate(plane, fuel_current) * self.len()
    
    def time(self, plane: Plane, fuel_current: float) -> float:
        return self.len() / self.v_effective(plane.v_mass(fuel_current))

class World:
    def __init__(self):
        self.cities = []
        self.roads = []
        self.dct = {}

    def add_city(self, name, lat, lon, has_fuel: bool = True):
        city = City(name, lat, lon, has_fuel)
        self.cities.append(city)
        return city
    
    def add_road(self, city1, city2, wind_direction):
        road1 = Road(city1, city2, wind_direction)
        road2 = Road(city2, city1, wind_direction)
        self.roads.append(road1)
        self.roads.append(road2)
        return road1, road2
    
    def make_dct(self):
        for city in self.cities:
            self.dct[city] = []
            for road in self.roads:
                if road.city1 == city:
                    self.dct[city].append((road, road.city2))
        return self.dct
    
